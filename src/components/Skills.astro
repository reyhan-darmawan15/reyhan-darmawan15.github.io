---
const skillGroups = [
  {
    category: "Embedded System",
    tags: ["STM32", "ATMEGA AVR", "Arduino"],
  },
  {
    category: "Programming",
    tags: ["C/C++", "Python", "C# (WinForms)", "SQL", "RPA UiPath"],
  },
  {
    category: "Game Dev",
    tags: [
      "Visual Studio",
      "Git",
      "Blender",
      "Unreal Engine 5",
      "VRoid Studio",
      "FMOD Studio",
    ],
  },
];
---

<section id="skills">
  <div class="container">
    <div class="section-label">02 / SKILLS</div>
    <div class="section-title">Technical Skills</div>

    <div class="skills-grid">
      {
        skillGroups.map((group) => (
          <div class="panel skill-card">
            <h3>{group.category}</h3>
            <div class="tags">
              {group.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
